# ─────────────────────────────────────────────────────────────
#  Plantilla de variables de entorno (SÍ se sube a git, sin secretos)
#  Copia este archivo como `.env.local` y rellena los valores reales.
# ─────────────────────────────────────────────────────────────

# Clave de OpenAI para BellA (asistente IA). SOLO servidor — sin NEXT_PUBLIC_.
# Obténla en https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo a usar por BellA. Opcional (por defecto: gpt-4o-mini).
BELLA_MODEL=gpt-4o-mini
